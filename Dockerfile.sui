FROM rust:latest

# Install Sui CLI
RUN cargo install --locked --git https://github.com/MystenLabs/sui.git --branch main sui

# Install OneChain dependencies
RUN apt-get update && apt-get install -y git

WORKDIR /app

# Copy contracts
COPY contracts/ /app/contracts/

WORKDIR /app/contracts

RUN echo "=== Building Move contracts ===" && \
    sui move build

RUN echo "=== Contracts built successfully ===" && \
    ls -la build/
